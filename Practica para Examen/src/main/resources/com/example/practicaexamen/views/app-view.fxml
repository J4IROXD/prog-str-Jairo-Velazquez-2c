<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AppController">
   <children>
      <Label text="Listado de contactos" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Nombre" />
            <Label text="Teléfono" GridPane.rowIndex="1" />
            <Label text="Parentesco" GridPane.rowIndex="2" />
            <TextField fx:id="txtNombre" GridPane.columnIndex="1" />
            <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1" />
             <ComboBox fx:id="cmbParentesco" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onAgregar" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#onBuscar" text="Buscar" />
            <Button mnemonicParsing="false" onAction="#onActualizar" text="Actualizar" />
            <Button mnemonicParsing="false" onAction="#onEliminar" text="Eliminar" />
            <Button layoutX="166.0" layoutY="10.0" mnemonicParsing="false" onAction="#onLimpiar" text="Limpiar" />
         </children>
      </HBox>
      <ListView fx:id="listaContactos" prefHeight="180.0" prefWidth="600.0" />
      <Label />
   </children>
</VBox>
